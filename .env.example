# Colombia Green Coffee — Variables de entorno
# Copia: cp .env.example .env.local  (Windows: copy .env.example .env.local)
# Automatización completa: npm run setup:all | npm run setup:ecosystem
# Ecosistema: copia .env.ecosystem.example → C:\Users\LENOVO\Projects\.env.ecosystem.local

# === Base de datos ===
# Local: SQLite en ./data/colombia-green-coffee.db
DATABASE_URL=./data/colombia-green-coffee.db

# === Automatización setup:all (rellena antes de npm run setup:all) ===
GITHUB_REPO=lasucursaldelcafe-droid/Coffee-hunter-cov2
TURSO_DB_NAME=colombia-green-coffee
# TURSO_ORG=                    # slug org Turso (si tienes varias)
# TURSO_PLATFORM_TOKEN=         # https://turso.tech/app → Settings → Tokens (tso_...)
# VERCEL_TOKEN=                 # https://vercel.com/account/tokens
# VERCEL_ORG_ID=                # (auto) Team ID — lo rellena setup:all
# VERCEL_PROJECT_ID=            # (auto) Project ID — lo rellena setup:all
VERCEL_PROJECT_NAME=colombia-green-coffee

# Producción (Vercel + Turso — patrón empresario-virtual)
# TURSO_DATABASE_URL=libsql://colombia-green-coffee-xxx.turso.io
# TURSO_AUTH_TOKEN=

# URL pública (Vercel) — OAuth y CORS
# NEXT_PUBLIC_APP_URL=https://colombia-green-coffee.vercel.app

# === Seguridad (generada por npm run setup) ===
ENCRYPTION_KEY=

# === Contacto La Sucursal del Café ===
MAIN_EMAIL=lasucursaldelcafe@gmail.com

# === Email transaccional (Resend) ===
# RESEND_API_KEY=re_...
# EMAIL_FROM=Colombia Green Coffee <onboarding@tudominio.com>
NEXT_PUBLIC_WHATSAPP=573116699638
NEXT_PUBLIC_INSTAGRAM=lasucursaldelcafe

# === Google OAuth (futuro panel de tiendas) ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# === Formularios → Google Sheets (patrón feria-cafe-inscripcion) ===
# URL del Apps Script /exec para respaldar inscripciones
# SHEETS_WEB_APP_URL=

# === Firebase (opcional — hosting espejo) ===
# FIREBASE_PROJECT_ID=la-sucursal-del-cafe

NODE_ENV=development
