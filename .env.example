# Colombia Green Coffee — Variables de entorno
# Copia: cp .env.example .env.local
# Luego: npm run setup && npm run db:init

# === Base de datos ===
# Local: SQLite en ./data/colombia-green-coffee.db
DATABASE_URL=./data/colombia-green-coffee.db

# Producción (Vercel + Turso — patrón empresario-virtual)
# TURSO_DATABASE_URL=libsql://colombia-green-coffee-xxx.turso.io
# TURSO_AUTH_TOKEN=
# TURSO_PLATFORM_TOKEN=

# URL pública (Vercel) — OAuth y CORS
# NEXT_PUBLIC_APP_URL=https://colombia-green-coffee.vercel.app

# === Seguridad (generada por npm run setup) ===
ENCRYPTION_KEY=

# === Contacto La Sucursal del Café ===
MAIN_EMAIL=lasucursaldelcafe@gmail.com
NEXT_PUBLIC_WHATSAPP=573116699638
NEXT_PUBLIC_INSTAGRAM=lasucursaldelcafe

# === Google OAuth (futuro panel de tiendas) ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# === Formularios → Google Sheets (patrón feria-cafe-inscripcion) ===
# URL del Apps Script /exec para respaldar inscripciones
# SHEETS_WEB_APP_URL=

# === Firebase (opcional — hosting espejo) ===
# FIREBASE_PROJECT_ID=la-sucursal-del-cafe

NODE_ENV=development
